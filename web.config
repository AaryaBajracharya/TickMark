<configuration>
  <system.webServer>
    
    <handlers>
      <add name="iisnode" path="./backend/index.js" verb="*" modules="iisnode" />
    </handlers>
    
    <defaultDocument enabled="true">
      <files>
        <add value="./backend/index.js" />
      </files>
    </defaultDocument>
    
  </system.webServer>
</configuration>
